NODE_ENV=production
YANTO_NODE_ROLE=master
PORT=8080
DATABASE_URL=postgres://yanto:yanto@postgres:5432/yanto
JWT_SECRET=change-this-to-a-long-random-secret
YANTO_SETUP_CODE=
# Legacy upgrades only. Existing ADMIN_USERNAME/ADMIN_PASSWORD values are
# migrated into the database owner when no account exists yet.
# ADMIN_USERNAME=admin
# ADMIN_PASSWORD=
PROJECTS_ROOT=/projects
HOST_PROJECTS_ROOT=/var/lib/yanto/projects
AGENT_WORKTREES_ROOT=/projects/.yanto-worktrees
HOST_AGENT_WORKTREES_ROOT=/var/lib/yanto/projects/.yanto-worktrees
SSH_KEYS_DIR=/data/ssh
SSH_SOURCE_DIR=/var/lib/yanto/ssh-source
SSH_PRIVATE_KEY_PATH=/root/.ssh/id_ed25519
MANAGED_SSH_PRIVATE_KEY_PATH=/data/ssh/id_ed25519
APP_BASE_URL=http://localhost:8080
COMMAND_TIMEOUT_MS=3600000
COMMAND_OUTPUT_MAX_BYTES=2097152
DEPLOYMENT_LOG_MAX_CHARS=500000
COOKIE_SECURE=false
WORKER_JOIN_TOKEN=change-this-worker-join-token
WORKER_TOKEN_SECRET=change-this-worker-token-secret
YANTO_MASTER_URL=http://127.0.0.1:8080
YANTO_WORKER_TOKEN=
YANTO_WORKER_NAME=
FRP_BIND_PORT=7000
FRP_PORT_START=25560
FRP_PORT_END=25600

NODE_ENV=production
YANTO_NODE_ROLE=master
PORT=8080
DATABASE_URL=postgres://yanto:yanto@postgres:5432/yanto
JWT_SECRET=change-this-to-a-long-random-secret
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-this-admin-password
PROJECTS_ROOT=/projects
HOST_PROJECTS_ROOT=~/projects
SSH_KEYS_DIR=/data/ssh
SSH_SOURCE_DIR=/home/ubuntu/.ssh
SSH_PRIVATE_KEY_PATH=/root/.ssh/id_ed25519
MANAGED_SSH_PRIVATE_KEY_PATH=/data/ssh/id_ed25519
APP_BASE_URL=http://localhost:8080
COMMAND_TIMEOUT_MS=3600000
COMMAND_OUTPUT_MAX_BYTES=2097152
DEPLOYMENT_LOG_MAX_CHARS=500000
COOKIE_SECURE=false
WORKER_JOIN_TOKEN=change-this-worker-join-token
WORKER_TOKEN_SECRET=change-this-worker-token-secret
YANTO_MASTER_URL=http://127.0.0.1:8080
YANTO_WORKER_TOKEN=
YANTO_WORKER_NAME=
